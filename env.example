# ============================================
# 🔥 TI-LEX-AL — Variables d'environnement
# ============================================
# 
# Configure ces variables dans Vercel :
# Dashboard → Settings → Environment Variables
#
# ============================================

# ✅ REQUIS — Clé API OpenAI (pour GPT-4o-mini)
# Obtiens ta clé sur : https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 🔍 OPTIONNEL — Clé SerpAPI (pour la recherche Google)
# Obtiens ta clé sur : https://serpapi.com/
# Si pas configurée, la recherche utilisera GPT comme fallback
SERPAPI_KEY=

# 🔍 OPTIONNEL — Clé SearchAPI.io (alternative à SerpAPI)
# Obtiens ta clé sur : https://www.searchapi.io/
SEARCH_API_KEY=
