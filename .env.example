# Clé API Anthropic — obligatoire pour /api/chat
# Créer une clé sur https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optionnel : modèle Claude à utiliser (défaut : claude-haiku-4-5)
# Autres choix : claude-sonnet-4-6, claude-opus-4-7
ANTHROPIC_MODEL=claude-haiku-4-5

# Optionnel : nombre max de tokens par réponse (défaut : 1024)
ANTHROPIC_MAX_TOKENS=1024
